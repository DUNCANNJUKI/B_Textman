# Environment Variables Template
# Copy this file to .env.local and fill in your values

# ======================
# SUPABASE CONFIGURATION
# ======================

# Your Supabase project URL
# Find this in: Supabase Dashboard > Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key
# Find this in: Supabase Dashboard > Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ======================
# DEVELOPMENT CONFIGURATION
# ======================

# Set to development for local development
NODE_ENV=development

# Enable development mode features
VITE_DEV_MODE=true

# ======================
# OPTIONAL: LOCAL SUPABASE
# ======================
# If running Supabase locally, use these instead:

# VITE_SUPABASE_URL=http://localhost:54321
# VITE_SUPABASE_ANON_KEY=your-local-anon-key

# ======================
# PRODUCTION DEPLOYMENT
# ======================
# For production deployments, set:

# NODE_ENV=production
# VITE_DEV_MODE=false

# ======================
# CURRENT PROJECT VALUES
# ======================
# Your current Lovable project uses:
# Project ID: rtgcrclgmvcmrjpvtpwm
# URL: https://rtgcrclgmvcmrjpvtpwm.supabase.co
# 
# To get your anon key:
# 1. Go to https://supabase.com/dashboard/project/rtgcrclgmvcmrjpvtpwm
# 2. Navigate to Settings > API
# 3. Copy the "anon public" key

# ======================
# SERVER / MIGRATION KEYS
# ======================
# The following keys are sensitive and should only be used in CI or server environments.
# Do NOT expose these in client-side code.

# Supabase service_role key (used for server-side operations and migrations)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database connection URL (used by migration tools in CI)
# SUPABASE_DB_URL=postgres://user:pass@db-host:5432/dbname

# Supabase CI deploy token and project reference (for supabase CLI)
# SUPABASE_ACCESS_TOKEN=your-supabase-cli-token
# SUPABASE_PROJECT_REF=rtgcrclgmvcmrjpvtpwm